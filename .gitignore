# Scan output: real scan results are generated artifacts and are NOT committed.
# Only the synthetic demo fixtures (so the dashboard renders out-of-the-box) and
# the index that lists them are tracked.
dashboard/data/*.json
!dashboard/data/index.json
!dashboard/data/sample-web-app.json
!dashboard/data/internal-api.json

# Generated dashboard bundle (may contain private scan data). Regenerated on
# every scan; the dashboard falls back to fetching JSON when it's absent.
dashboard/data/findings.js

